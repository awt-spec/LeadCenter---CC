generator client {
  provider        = "prisma-client-js"
  // OPT-011: habilita `relationLoadStrategy: 'join'` para que los includes
  // se materialicen con LATERAL JOINs en una sola query SQL en lugar de
  // queries separadas. Reduce N+1 implícito en findMany con includes
  // anidados (timeline de actividad, task drawer, opp detail).
  previewFeatures = ["relationJoins"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ==================== AUTH & RBAC ====================

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String
  avatarUrl     String?
  passwordHash  String?
  googleId      String?   @unique
  isActive      Boolean   @default(true)
  lastLoginAt   DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  roles                  UserRole[]
  sessions               Session[]
  auditLogs              AuditLog[]
  ownedContacts          Contact[]       @relation("ContactOwner")
  createdContacts        Contact[]       @relation("ContactCreator")
  importBatches          ImportBatch[]
  ownedAccounts          Account[]       @relation("AccountOwner")
  createdAccounts        Account[]       @relation("AccountCreator")
  ownedOpportunities     Opportunity[]   @relation("OpportunityOwner")
  createdOpportunities   Opportunity[]   @relation("OpportunityCreator")
  stageChanges           StageHistory[]
  createdActivities      Activity[]          @relation("ActivityCreator")
  nextActionAssignments  Activity[]          @relation("NextActionAssignee")
  mentions               ActivityMention[]   @relation("ActivityMentions")
  activityAssignees      ActivityAssignee[]
  notifications          Notification[]
  ownedCampaigns         Campaign[]      @relation("CampaignOwner")
  createdCampaigns       Campaign[]      @relation("CampaignCreator")
  createdTasks           Task[]          @relation("TaskCreator")
  taskAssignees          TaskAssignee[]  @relation("TaskAssignees")
  taskComments           TaskComment[]   @relation("TaskCommenter")
  taskAttachments        TaskAttachment[] @relation("TaskUploader")

  connectedIntegrations  Integration[]   @relation("IntegrationConnector")
  triggeredSyncRuns      SyncRun[]       @relation("SyncTrigger")

  // C.O.C. — Contexto Organizacional Compartido
  createdSharedContexts        SharedContext[]        @relation("SharedContextCreator")
  updatedSharedContexts        SharedContext[]        @relation("SharedContextUpdater")
  updatedSharedContextVersions SharedContextVersion[] @relation("SharedContextVersionUpdater")
  createdSharedContextLinks    SharedContextLink[]    @relation("SharedContextLinkCreator")

  // Puntos de control (checkpoints) en oportunidades
  createdCheckpoints           OpportunityCheckpoint[] @relation("CheckpointCreator")
  assignedCheckpoints          OpportunityCheckpoint[] @relation("CheckpointAssignee")
  completedCheckpoints         OpportunityCheckpoint[] @relation("CheckpointCompleter")

  @@index([email])
}

model Role {
  id           String           @id @default(cuid())
  key          String           @unique
  name         String
  description  String?
  isSystem     Boolean          @default(false)
  createdAt    DateTime         @default(now())

  users        UserRole[]
  permissions  RolePermission[]
}

model Permission {
  id           String           @id @default(cuid())
  key          String           @unique
  resource     String
  action       String
  description  String?

  roles        RolePermission[]

  @@index([resource])
}

model UserRole {
  userId    String
  roleId    String
  grantedAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  role      Role     @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
}

model RolePermission {
  roleId       String
  permissionId String

  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  ipAddress    String?
  userAgent    String?

  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// ==================== AUDIT LOG ====================

model AuditLog {
  id         String   @id @default(cuid())
  userId     String?
  action     String
  resource   String
  resourceId String?
  changes    Json?
  metadata   Json?
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime @default(now())

  user       User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([resource, resourceId])
  @@index([createdAt])
}

// ==================== ACCOUNTS ====================

model Account {
  id               String   @id @default(cuid())

  name             String
  legalName        String?
  domain           String?  @unique
  website          String?

  segment          MarketSegment?
  industry         String?
  subIndustry      String?
  size             CompanySize    @default(UNKNOWN)
  employeeCount    Int?
  annualRevenue    Decimal?       @db.Decimal(18, 2)
  currency         String         @default("USD")

  country          String?
  region           String?
  city             String?
  address          String?

  status           AccountStatus  @default(PROSPECT)
  priority         AccountPriority @default(NORMAL)
  ownerId          String?
  owner            User?          @relation("AccountOwner", fields: [ownerId], references: [id], onDelete: SetNull)
  parentAccountId  String?
  parentAccount    Account?       @relation("AccountHierarchy", fields: [parentAccountId], references: [id], onDelete: SetNull)
  childAccounts    Account[]      @relation("AccountHierarchy")

  description      String?        @db.Text
  internalNotes    String?        @db.Text
  /// Resumen preciso de indagaciones offline (calls, demos, pasillo, eventos…).
  /// Se renderiza solo cuando tiene contenido — no mostramos card vacía.
  offlineResearch  String?        @db.Text
  /// True cuando el dominio es sintético (ej. .lc-imported) o falta.
  /// La UI muestra un badge rojo "Sin dominio · revisar" para que un humano
  /// agregue el dominio real y permita merging con futuros syncs.
  needsDomainReview Boolean       @default(false)

  createdById      String?
  createdBy        User?          @relation("AccountCreator", fields: [createdById], references: [id], onDelete: SetNull)
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  contacts         Contact[]
  opportunities    Opportunity[]
  activities       Activity[]
  tasks            Task[]
  customFields     CustomFieldValue[] @relation("AccountCustomFields")
  /// Contexto Organizacional Compartido — vista 360 visible a todo el equipo.
  /// Una sola entidad por cuenta, con múltiples versiones (audiencias) + recursos.
  sharedContext    SharedContext?

  /// Generated tsvector for full-text search. Maintained by Postgres.
  search_vector    Unsupported("tsvector")?

  @@index([name])
  @@index([domain])
  @@index([ownerId])
  @@index([country])
  @@index([status])
  @@index([priority])
}

enum AccountPriority {
  LOW
  NORMAL
  HIGH
  URGENT
}

enum CompanySize {
  UNKNOWN
  MICRO
  SMALL
  MEDIUM
  LARGE
  ENTERPRISE
}

enum AccountStatus {
  PROSPECT
  ACTIVE
  CUSTOMER
  PARTNER
  LOST
  INACTIVE
  BLOCKED
}

// ==================== CONTACTS ====================

model Contact {
  id               String   @id @default(cuid())

  email            String   @unique
  firstName        String
  lastName         String
  fullName         String

  avatarUrl        String?
  jobTitle         String?
  department       String?
  seniorityLevel   SeniorityLevel @default(UNKNOWN)

  companyName      String?
  accountId        String?
  account          Account?         @relation(fields: [accountId], references: [id], onDelete: SetNull)

  country          String?
  city             String?
  timezone         String?

  phone            String?
  mobilePhone      String?
  linkedinUrl      String?
  website          String?

  source           ContactSource    @default(UNKNOWN)
  sourceDetail     String?
  status           ContactStatus    @default(ACTIVE)
  ownerId          String?
  owner            User?            @relation("ContactOwner", fields: [ownerId], references: [id], onDelete: SetNull)

  marketSegment    MarketSegment?
  productInterest  ProductInterest[] @default([])

  optIn            Boolean          @default(false)
  optInDate        DateTime?
  doNotContact     Boolean          @default(false)

  lastContactedAt  DateTime?
  lastActivityAt   DateTime?
  engagementScore  Int              @default(0)

  notes            String?          @db.Text

  createdById      String?
  createdBy        User?            @relation("ContactCreator", fields: [createdById], references: [id], onDelete: SetNull)
  importBatchId    String?
  importBatch      ImportBatch?     @relation(fields: [importBatchId], references: [id], onDelete: SetNull)
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  tags             ContactTag[]
  opportunityRoles OpportunityContact[]
  activities       Activity[]
  participantIn    ActivityParticipant[]
  campaigns        CampaignContact[]
  tasks            Task[]
  customFields     CustomFieldValue[] @relation("ContactCustomFields")

  /// Generated tsvector for full-text search. Maintained by Postgres.
  search_vector    Unsupported("tsvector")?

  @@index([email])
  @@index([ownerId])
  @@index([status])
  @@index([country])
  @@index([accountId])
  @@index([createdAt])
  @@index([fullName])
  @@index([companyName])
  @@index([status, ownerId])
  @@index([accountId, status])
  @@index([marketSegment])
  @@index([source])
}

enum SeniorityLevel {
  UNKNOWN
  ANALYST
  MANAGER
  DIRECTOR
  VP
  C_LEVEL
  OWNER
}

enum ContactSource {
  UNKNOWN
  WEBSITE_CHAT
  WEBSITE_FORM
  LINKEDIN
  LINKEDIN_INBOUND
  LINKEDIN_OUTBOUND
  EMAIL_INBOUND
  REFERRAL
  EVENT
  WEBINAR
  OUTBOUND_CAMPAIGN
  CSV_IMPORT
  MANUAL
  PARTNER
}

enum ContactStatus {
  ACTIVE
  NURTURE
  COLD
  DO_NOT_CONTACT
  UNSUBSCRIBED
  BOUNCED
  ARCHIVED
}

enum MarketSegment {
  BANK
  FINANCE_COMPANY
  MICROFINANCE
  COOPERATIVE
  PENSION_FUND
  INSURANCE
  FINTECH
  RETAIL
  CONSULTING
  OTHER
}

enum ProductInterest {
  SAF_PLUS
  SAF_LEASING
  SAF_FACTORING
  FILEMASTER
  FACTORAJE_ONCLOUD
  SYSDE_PENSION
  SENTINEL_PLD
}

model Tag {
  id          String       @id @default(cuid())
  name        String       @unique
  color       String       @default("#64748B")
  description String?
  createdAt   DateTime     @default(now())

  contacts    ContactTag[]
}

model ContactTag {
  contactId String
  tagId     String

  contact   Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)
  tag       Tag     @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([contactId, tagId])
}

// ==================== IMPORT BATCHES ====================

model ImportBatch {
  id              String            @id @default(cuid())
  fileName        String
  fileSize        Int
  totalRows       Int
  createdCount    Int               @default(0)
  updatedCount    Int               @default(0)
  skippedCount    Int               @default(0)
  failedCount     Int               @default(0)
  status          ImportStatus      @default(PENDING)
  columnMapping   Json
  dedupeStrategy  DedupeStrategy    @default(SKIP)
  defaultValues   Json?
  errors          Json?
  startedAt       DateTime?
  completedAt     DateTime?
  createdById     String
  createdBy       User              @relation(fields: [createdById], references: [id])
  createdAt       DateTime          @default(now())

  contacts        Contact[]

  @@index([createdById])
  @@index([status])
  @@index([createdAt])
}

enum ImportStatus {
  PENDING
  PROCESSING
  COMPLETED
  COMPLETED_WITH_ERRORS
  FAILED
}

enum DedupeStrategy {
  SKIP
  UPDATE
  CREATE_NEW
}

// ==================== OPPORTUNITIES ====================

model Opportunity {
  id                  String   @id @default(cuid())

  name                String
  code                String?  @unique

  accountId           String
  account             Account  @relation(fields: [accountId], references: [id], onDelete: Cascade)

  product             SysdeProduct
  subProduct          SysdeSubProduct?

  stage               OpportunityStage  @default(LEAD)
  stageChangedAt      DateTime          @default(now())
  previousStage       OpportunityStage?
  status              OpportunityStatus @default(OPEN)

  rating              OpportunityRating @default(UNSCORED)
  probability         Int               @default(10)

  estimatedValue      Decimal?          @db.Decimal(18, 2)
  currency            String            @default("USD")
  commercialModel     CommercialModel   @default(UNDEFINED)

  portfolioAmount     Decimal?          @db.Decimal(18, 2)
  userCount           Int?
  annualOperations    Int?
  clientCount         Int?
  officeCount         Int?

  expectedCloseDate   DateTime?
  closedAt            DateTime?
  lastActivityAt      DateTime?
  nextActionDate      DateTime?
  nextActionNote      String?

  source              ContactSource     @default(UNKNOWN)
  sourceDetail        String?
  isDirectProspecting Boolean           @default(false)
  referredById        String?

  lostReason          LostReason?
  lostReasonDetail    String?
  competitorWon       String?
  wonReason           String?

  ownerId             String?
  owner               User?             @relation("OpportunityOwner", fields: [ownerId], references: [id], onDelete: SetNull)

  description         String?           @db.Text
  internalNotes       String?           @db.Text

  createdById         String?
  createdBy           User?             @relation("OpportunityCreator", fields: [createdById], references: [id], onDelete: SetNull)
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt

  contactRoles        OpportunityContact[]
  stageHistory        StageHistory[]
  activities          Activity[]
  tasks               Task[]
  customFields        CustomFieldValue[] @relation("OpportunityCustomFields")
  checkpoints         OpportunityCheckpoint[]

  campaignId          String?
  campaign            Campaign?         @relation("CampaignOpportunities", fields: [campaignId], references: [id], onDelete: SetNull)

  @@index([accountId])
  @@index([ownerId])
  @@index([stage])
  @@index([status])
  @@index([campaignId])
  @@index([product])
  @@index([expectedCloseDate])
  @@index([createdAt])
}

enum OpportunityStage {
  LEAD
  DISCOVERY
  SIZING
  DEMO
  PROPOSAL
  NEGOTIATION
  CLOSING
  HANDOFF
  WON
  LOST
  STAND_BY
  NURTURE
}

enum OpportunityStatus {
  OPEN
  WON
  LOST
  STAND_BY
  NURTURE
}

enum OpportunityRating {
  UNSCORED
  A_PLUS
  A
  B_PLUS
  B
  C
  D
}

enum SysdeProduct {
  SAF_PLUS
  FILEMASTER
  FACTORAJE_ONCLOUD
  SYSDE_PENSION
  SENTINEL_PLD
  CUSTOM
}

enum SysdeSubProduct {
  SAF_CREDIT
  SAF_LEASING
  SAF_FACTORING
  SAF_FULL
  FM_DOCUMENTS
  FM_BPM
  FM_FULL
  PENSION_RECORDKEEPING
  PLD_FULL
  PLD_MONITORING
  FACTORAJE_REVERSE
  FACTORAJE_DIRECT
  NONE
}

enum CommercialModel {
  UNDEFINED
  SAAS
  ON_PREMISE
  HYBRID
  LICENSE_PERPETUAL
  TIME_AND_MATERIALS
}

enum LostReason {
  PRICE
  COMPETITOR
  TIMING
  NO_BUDGET
  NO_DECISION
  NO_FIT
  INTERNAL_DEV
  NO_RESPONSE
  PROJECT_CANCELLED
  OTHER
}

model OpportunityContact {
  opportunityId String
  contactId     String
  role          ContactRole  @default(INFLUENCER)
  isPrimary     Boolean      @default(false)
  notes         String?
  addedAt       DateTime     @default(now())

  opportunity   Opportunity  @relation(fields: [opportunityId], references: [id], onDelete: Cascade)
  contact       Contact      @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@id([opportunityId, contactId])
  @@index([contactId])
}

enum ContactRole {
  SPONSOR
  DECISION_MAKER
  CHAMPION
  TECHNICAL_BUYER
  USER
  INFLUENCER
  BLOCKER
  GATEKEEPER
}

model StageHistory {
  id                  String           @id @default(cuid())
  opportunityId       String
  fromStage           OpportunityStage?
  toStage             OpportunityStage
  changedById         String?
  changedAt           DateTime         @default(now())
  daysInPreviousStage Int?
  notes               String?

  opportunity         Opportunity      @relation(fields: [opportunityId], references: [id], onDelete: Cascade)
  changedBy           User?            @relation(fields: [changedById], references: [id], onDelete: SetNull)

  @@index([opportunityId])
  @@index([changedAt])
}

// ==================== ACTIVITIES ====================

model Activity {
  id                    String          @id @default(cuid())

  type                  ActivityType
  subtype               String?
  subject               String
  bodyJson              Json?
  bodyText              String?         @db.Text

  tags                  ActivityTag[]   @default([])

  occurredAt            DateTime        @default(now())
  durationMinutes       Int?

  contactId             String?
  contact               Contact?        @relation(fields: [contactId], references: [id], onDelete: Cascade)

  accountId             String?
  account               Account?        @relation(fields: [accountId], references: [id], onDelete: Cascade)

  opportunityId         String?
  opportunity           Opportunity?    @relation(fields: [opportunityId], references: [id], onDelete: Cascade)

  participants          ActivityParticipant[]
  mentions              ActivityMention[]
  assignees             ActivityAssignee[]

  nextActionType        NextActionType?
  nextActionNote        String?
  nextActionDate        DateTime?
  nextActionAssigneeId  String?
  nextActionAssignee    User?           @relation("NextActionAssignee", fields: [nextActionAssigneeId], references: [id], onDelete: SetNull)
  nextActionCompleted   Boolean         @default(false)
  nextActionCompletedAt DateTime?

  outcome               ActivityOutcome?

  attachments           ActivityAttachment[]

  isSystemGenerated     Boolean         @default(false)
  systemEventType       String?
  systemMetadata        Json?

  templateKey           String?

  createdById           String
  createdBy             User            @relation("ActivityCreator", fields: [createdById], references: [id])
  createdAt             DateTime        @default(now())
  updatedAt             DateTime        @updatedAt

  @@index([contactId])
  @@index([accountId])
  @@index([opportunityId])
  @@index([createdById])
  @@index([occurredAt])
  @@index([type])
  @@index([nextActionDate])
}

enum ActivityType {
  CALL
  EMAIL_SENT
  EMAIL_RECEIVED
  WHATSAPP
  MEETING
  DEMO
  MATERIAL_SENT
  PROPOSAL_SENT
  INTERNAL_NOTE
  TASK
  STAGE_CHANGE
  CONTACT_LINKED
  STATUS_CHANGE
  FILE_SHARED
  LINKEDIN_MESSAGE
  EVENT_ATTENDED
}

enum ActivityTag {
  BL
  INFO
  CONSUL
  SOLIC
  URGENT
  FOLLOWUP
  WIN_SIGNAL
  RISK_SIGNAL
}

enum ActivityOutcome {
  POSITIVE
  NEUTRAL
  NEGATIVE
  BLOCKER
  NO_RESPONSE
}

enum NextActionType {
  CALL
  EMAIL
  WHATSAPP
  MEETING
  DEMO
  SEND_PROPOSAL
  SEND_MATERIAL
  INTERNAL_TASK
  WAIT_FOR_CLIENT
  OTHER
}

model ActivityParticipant {
  activityId String
  contactId  String
  role       String?

  activity   Activity @relation(fields: [activityId], references: [id], onDelete: Cascade)
  contact    Contact  @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@id([activityId, contactId])
}

model ActivityMention {
  activityId      String
  mentionedUserId String
  readAt          DateTime?

  activity        Activity @relation(fields: [activityId], references: [id], onDelete: Cascade)
  mentionedUser   User     @relation("ActivityMentions", fields: [mentionedUserId], references: [id], onDelete: Cascade)

  @@id([activityId, mentionedUserId])
  @@index([mentionedUserId, readAt])
}

model ActivityAssignee {
  activityId String
  userId     String
  assignedAt DateTime @default(now())

  activity   Activity @relation(fields: [activityId], references: [id], onDelete: Cascade)
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([activityId, userId])
  @@index([userId])
}

model ActivityAttachment {
  id         String   @id @default(cuid())
  activityId String
  fileName   String
  fileUrl    String
  fileSize   Int
  mimeType   String
  uploadedAt DateTime @default(now())

  activity   Activity @relation(fields: [activityId], references: [id], onDelete: Cascade)

  @@index([activityId])
}

// ==================== NOTIFICATIONS ====================

model Notification {
  id         String   @id @default(cuid())
  userId     String
  type       NotificationType
  title      String
  body       String?
  link       String?
  isRead     Boolean  @default(false)
  readAt     DateTime?
  metadata   Json?
  createdAt  DateTime @default(now())

  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
  @@index([createdAt])
}

enum NotificationType {
  MENTION
  ASSIGNED_NEXT_ACTION
  NEXT_ACTION_DUE
  OPPORTUNITY_STALE
  STAGE_CHANGED
  CONTACT_ASSIGNED
  SYSTEM
}

// ==================== CAMPAIGNS ====================

model Campaign {
  id             String          @id @default(cuid())

  name           String
  code           String?         @unique
  description    String?         @db.Text
  type           CampaignType    @default(MIXED)
  status         CampaignStatus  @default(DRAFT)

  goal           CampaignGoal    @default(LEAD_GEN)
  targetSegment  MarketSegment?
  targetProduct  ProductInterest[] @default([])
  targetCountry  String?

  startDate      DateTime?
  endDate        DateTime?

  budget         Decimal?        @db.Decimal(18, 2)
  spent          Decimal?        @db.Decimal(18, 2)
  currency       String          @default("USD")

  ownerId        String?
  owner          User?           @relation("CampaignOwner", fields: [ownerId], references: [id], onDelete: SetNull)

  createdById    String?
  createdBy      User?           @relation("CampaignCreator", fields: [createdById], references: [id], onDelete: SetNull)

  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  contacts       CampaignContact[]
  steps          CampaignStep[]
  opportunities  Opportunity[]   @relation("CampaignOpportunities")

  @@index([status])
  @@index([type])
  @@index([ownerId])
  @@index([startDate])
}

enum CampaignType {
  EMAIL_DRIP
  COLD_OUTBOUND
  WEBINAR
  EVENT
  REFERRAL
  CONTENT
  PARTNER
  PAID_ADS
  MIXED
}

enum CampaignStatus {
  DRAFT
  ACTIVE
  PAUSED
  COMPLETED
  ARCHIVED
}

enum CampaignGoal {
  AWARENESS
  LEAD_GEN
  CONVERSION
  RETENTION
  REFERRAL
  EVENT_REGISTRATION
}

model CampaignStep {
  id          String           @id @default(cuid())
  campaignId  String
  campaign    Campaign         @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  order       Int
  type        CampaignStepType
  name        String
  delayDays   Int              @default(0)

  emailSubject String?
  emailBody    String?         @db.Text
  callScript   String?         @db.Text
  taskTitle    String?
  notes        String?         @db.Text

  /// Optional audience filter for this step. If non-empty, the step will only
  /// fire for enrolled contacts whose seniorityLevel is in this list.
  /// Empty array = sin filtro (todos los enrolled).
  targetSeniority SeniorityLevel[] @default([])

  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@index([campaignId, order])
}

enum CampaignStepType {
  EMAIL
  WAIT
  CALL
  TASK
  LINKEDIN
  WHATSAPP
  EVENT_INVITE
  BRANCH
}

model CampaignContact {
  campaignId    String
  contactId     String

  campaign      Campaign        @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  contact       Contact         @relation(fields: [contactId], references: [id], onDelete: Cascade)

  status        CampaignContactStatus @default(ACTIVE)
  enrolledAt    DateTime        @default(now())
  completedAt   DateTime?
  unsubscribedAt DateTime?
  bouncedAt     DateTime?

  currentStepId String?
  notes         String?

  @@id([campaignId, contactId])
  @@index([contactId])
  @@index([status])
}

enum CampaignContactStatus {
  ACTIVE
  PAUSED
  COMPLETED
  UNSUBSCRIBED
  BOUNCED
  REPLIED
  CONVERTED
}

// ==================== CUSTOM FIELDS (flexible schema per entity) ====================

model CustomFieldDefinition {
  id          String          @id @default(cuid())
  entity      CustomFieldEntity
  key         String
  label       String
  type        CustomFieldType
  options     Json?
  required    Boolean         @default(false)
  position    Int             @default(0)
  description String?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  values      CustomFieldValue[]

  @@unique([entity, key])
  @@index([entity, position])
}

enum CustomFieldEntity {
  CONTACT
  ACCOUNT
  OPPORTUNITY
}

enum CustomFieldType {
  TEXT
  LONG_TEXT
  NUMBER
  DATE
  BOOLEAN
  SELECT
  MULTI_SELECT
  URL
  EMAIL
  PHONE
}

model CustomFieldValue {
  id            String   @id @default(cuid())
  fieldId       String
  field         CustomFieldDefinition @relation(fields: [fieldId], references: [id], onDelete: Cascade)

  contactId     String?
  contact       Contact? @relation("ContactCustomFields", fields: [contactId], references: [id], onDelete: Cascade)

  accountId     String?
  account       Account? @relation("AccountCustomFields", fields: [accountId], references: [id], onDelete: Cascade)

  opportunityId String?
  opportunity   Opportunity? @relation("OpportunityCustomFields", fields: [opportunityId], references: [id], onDelete: Cascade)

  value         Json
  updatedAt     DateTime @updatedAt

  @@unique([fieldId, contactId])
  @@unique([fieldId, accountId])
  @@unique([fieldId, opportunityId])
  @@index([contactId])
  @@index([accountId])
  @@index([opportunityId])
}

// ==================== TASKS (Asana-style task board per account) ====================

model Task {
  id           String         @id @default(cuid())

  title        String
  description  String?        @db.Text
  status       TaskStatus     @default(TODO)
  priority     TaskPriority   @default(NORMAL)

  dueDate      DateTime?
  startDate    DateTime?
  completedAt  DateTime?

  position     Int            @default(0)

  accountId    String?
  account      Account?       @relation(fields: [accountId], references: [id], onDelete: Cascade)

  opportunityId String?
  opportunity   Opportunity?  @relation(fields: [opportunityId], references: [id], onDelete: SetNull)

  contactId    String?
  contact      Contact?       @relation(fields: [contactId], references: [id], onDelete: SetNull)

  parentTaskId String?
  parentTask   Task?          @relation("TaskSubtasks", fields: [parentTaskId], references: [id], onDelete: Cascade)
  subtasks     Task[]         @relation("TaskSubtasks")

  createdById  String
  createdBy    User           @relation("TaskCreator", fields: [createdById], references: [id])

  assignees    TaskAssignee[]
  comments     TaskComment[]
  attachments  TaskAttachment[]

  /// Tasks that must complete before this one (this task is blocked).
  blockedBy    TaskDependency[] @relation("TaskBlockedBy")
  /// Tasks that this one is blocking.
  blocking     TaskDependency[] @relation("TaskBlocking")

  tags         String[]       @default([])
  /// Optional accent color (hex) for visual grouping in views.
  color        String?

  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  @@index([accountId, status])
  @@index([accountId, priority])
  @@index([opportunityId])
  @@index([createdById])
  @@index([dueDate])
  @@index([status, dueDate])
  @@index([parentTaskId])
}

enum TaskStatus {
  BACKLOG
  TODO
  IN_PROGRESS
  REVIEW
  BLOCKED
  DONE
  CANCELLED
}

enum TaskPriority {
  LOW
  NORMAL
  HIGH
  URGENT
}

model TaskAssignee {
  taskId     String
  userId     String
  assignedAt DateTime @default(now())

  task       Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user       User     @relation("TaskAssignees", fields: [userId], references: [id], onDelete: Cascade)

  @@id([taskId, userId])
  @@index([userId])
}

model TaskComment {
  id        String   @id @default(cuid())
  taskId    String
  userId    String
  body      String   @db.Text
  createdAt DateTime @default(now())
  editedAt  DateTime?

  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user      User     @relation("TaskCommenter", fields: [userId], references: [id], onDelete: Cascade)

  @@index([taskId, createdAt])
}

model TaskAttachment {
  id         String   @id @default(cuid())
  taskId     String
  fileName   String
  fileUrl    String
  fileSize   Int      @default(0)
  mimeType   String   @default("application/octet-stream")
  uploadedById String
  uploadedAt DateTime @default(now())

  task       Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  uploadedBy User     @relation("TaskUploader", fields: [uploadedById], references: [id], onDelete: Cascade)

  @@index([taskId])
}

model TaskDependency {
  taskId          String
  blockedByTaskId String
  createdAt       DateTime @default(now())

  task            Task     @relation("TaskBlockedBy", fields: [taskId], references: [id], onDelete: Cascade)
  blockedBy       Task     @relation("TaskBlocking", fields: [blockedByTaskId], references: [id], onDelete: Cascade)

  @@id([taskId, blockedByTaskId])
  @@index([blockedByTaskId])
}

// ==================== INTEGRATIONS ====================

/// External-system connections (HubSpot, Salesforce, etc.). One row per
/// provider+account pair. Tokens are stored AES-GCM encrypted at rest.
model Integration {
  id                String   @id @default(cuid())
  provider          String   // "hubspot" | "salesforce" | ...
  status            IntegrationStatus @default(DISCONNECTED)

  /// External account/portal identifier (HubSpot portalId / Salesforce orgId).
  externalAccountId String?
  ownerEmail        String?

  /// Encrypted access + refresh tokens (AES-256-GCM, key from AUTH_SECRET).
  encAccessToken    String?  @db.Text
  encRefreshToken   String?  @db.Text
  expiresAt         DateTime?
  scopes            String[] @default([])

  lastSyncedAt      DateTime?
  lastError         String?

  /// Resumable sync state. Lets each cron tick pick up where the previous
  /// truncated. Shape: { cursors: { companies?, contacts?, deals? },
  ///                     totals: { ..., fetchedAt },
  ///                     phase:  'companies' | 'deals' | 'contacts' | 'idle' }
  syncState         Json?    @default("{}")

  connectedById     String?
  connectedBy       User?    @relation("IntegrationConnector", fields: [connectedById], references: [id], onDelete: SetNull)

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  mappings          IntegrationMapping[]
  runs              SyncRun[]

  @@unique([provider, externalAccountId])
  @@index([status])
}

enum IntegrationStatus {
  DISCONNECTED
  CONNECTED
  ERROR
  SYNCING
}

/// Maps an external HubSpot/SF object id to its internal LeadCenter record.
/// Lets us idempotently upsert and detect deletes on re-sync.
model IntegrationMapping {
  id            String      @id @default(cuid())
  integrationId String
  integration   Integration @relation(fields: [integrationId], references: [id], onDelete: Cascade)

  externalType  String      // "company" | "contact" | "deal" | "task" | "note" | "engagement"
  externalId    String

  internalType  String      // "Account" | "Contact" | "Opportunity" | "Activity" | "Task"
  internalId    String

  lastSeenAt    DateTime    @default(now())
  lastSyncedAt  DateTime    @default(now())

  @@unique([integrationId, externalType, externalId])
  @@index([internalType, internalId])
}

/// One row per sync invocation. Useful for showing history/last-run/errors.
// ==================== Puntos de control / Checkpoints ====================
// Hitos que el equipo agenda en una oportunidad para no perder de vista
// fechas críticas: demos confirmadas, deadlines de propuesta, decisiones
// del cliente, revisiones internas. Cada checkpoint tiene un dueño,
// fecha objetivo y estado (pendiente / completado / vencido).

model OpportunityCheckpoint {
  id            String        @id @default(cuid())
  opportunityId String
  opportunity   Opportunity   @relation(fields: [opportunityId], references: [id], onDelete: Cascade)

  label         String
  description   String?       @db.Text
  type          CheckpointType @default(MILESTONE)
  priority      CheckpointPriority @default(NORMAL)

  /// Fecha objetivo. Si es null, el checkpoint es informativo (un hito ya
  /// alcanzado o uno sin deadline).
  dueDate       DateTime?
  /// Cuándo se marcó como completado. null = pendiente.
  completedAt   DateTime?
  completedById String?
  completedBy   User?         @relation("CheckpointCompleter", fields: [completedById], references: [id], onDelete: SetNull)

  /// Owner del checkpoint (puede diferir del owner de la opportunity).
  assigneeId    String?
  assignee      User?         @relation("CheckpointAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)

  createdAt     DateTime      @default(now())
  createdById   String
  createdBy     User          @relation("CheckpointCreator", fields: [createdById], references: [id], onDelete: Cascade)

  @@index([opportunityId])
  @@index([dueDate])
  @@index([assigneeId, completedAt])
}

enum CheckpointType {
  MILESTONE      /// Hito estructural (Demo confirmada, Propuesta firmada, Kick-off)
  REVIEW         /// Revisión interna del equipo (no involucra cliente)
  CLIENT_TOUCH   /// Contacto programado con cliente (call, follow-up)
  DECISION       /// Fecha de decisión externa (board approval, presupuesto)
  CUSTOM
}

enum CheckpointPriority {
  LOW
  NORMAL
  HIGH
  CRITICAL
}

model SyncRun {
  id            String      @id @default(cuid())
  integrationId String
  integration   Integration @relation(fields: [integrationId], references: [id], onDelete: Cascade)

  startedAt     DateTime    @default(now())
  finishedAt    DateTime?
  status        String      // "running" | "ok" | "error"
  trigger       String      @default("manual") // "manual" | "webhook" | "cron"
  itemsCreated  Int         @default(0)
  itemsUpdated  Int         @default(0)
  itemsSkipped  Int         @default(0)
  error         String?     @db.Text
  details       Json?

  triggeredById String?
  triggeredBy   User?       @relation("SyncTrigger", fields: [triggeredById], references: [id], onDelete: SetNull)

  @@index([integrationId, startedAt])
}

// ==================== C.O.C. — Contexto Organizacional Compartido ====================
// Vista 360 colaborativa por cuenta. Cualquier participante de LeadCenter puede
// leer/editar. Tiene un bloque de estrategia compartida + versiones por audiencia
// (qué le contamos al prospecto, al área financiera, al técnico, etc.) + un
// repositorio de recursos externos (Lovable, Slides, Figma, Notion, Loom…).

model SharedContext {
  id           String    @id @default(cuid())

  accountId    String    @unique
  account      Account   @relation(fields: [accountId], references: [id], onDelete: Cascade)

  /// Título corto que identifica esta narrativa (ej. "Estrategia 2026 para BCP").
  headline     String?
  /// El "play" — cómo vamos a ganar esta cuenta.
  strategy     String?   @db.Text
  /// Outcomes esperados, KPIs, fechas hito.
  goals        String?   @db.Text
  /// Riesgos identificados (técnicos, comerciales, políticos).
  risks        String?   @db.Text
  /// Próximos pasos que vamos a ejecutar.
  nextSteps    String?   @db.Text

  status       SharedContextStatus @default(ACTIVE)

  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  createdById  String?
  createdBy    User?     @relation("SharedContextCreator", fields: [createdById], references: [id], onDelete: SetNull)
  updatedById  String?
  updatedBy    User?     @relation("SharedContextUpdater", fields: [updatedById], references: [id], onDelete: SetNull)

  versions     SharedContextVersion[]
  links        SharedContextLink[]

  @@index([accountId])
}

/// Una versión por audiencia (PROSPECTO, INTERNO, FINANZAS, TÉCNICO, EJECUTIVO).
/// La unique [contextId, audience] evita duplicados — si necesitas ramificar,
/// duplica el contenido en otra audiencia o crea una segunda SharedContext.
model SharedContextVersion {
  id           String    @id @default(cuid())
  contextId    String
  context      SharedContext @relation(fields: [contextId], references: [id], onDelete: Cascade)

  audience     ContextAudience

  /// Cuerpo libre en markdown / texto plano. La UI no usa tiptap acá: editor
  /// minimalista para que cualquiera del equipo pueda escribir sin fricción.
  body         String?   @db.Text

  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  updatedById  String?
  updatedBy    User?     @relation("SharedContextVersionUpdater", fields: [updatedById], references: [id], onDelete: SetNull)

  @@unique([contextId, audience])
  @@index([contextId])
}

/// Recursos externos asociados al contexto: Lovable, Slides, Figma, Notion, Loom…
/// El tipo se autodetecta desde el dominio en /api/coc/preview.
model SharedContextLink {
  id           String    @id @default(cuid())
  contextId    String
  context      SharedContext @relation(fields: [contextId], references: [id], onDelete: Cascade)

  url          String
  title        String
  description  String?   @db.Text
  type         ContextLinkType @default(OTHER)
  /// Si está poblado, este recurso sólo aparece cuando se filtra por esa audiencia.
  audience     ContextAudience?

  domain       String?
  thumbnail    String?

  /// Orden en la UI (drag-reorder a futuro).
  position     Int       @default(0)

  createdAt    DateTime  @default(now())
  createdById  String?
  createdBy    User?     @relation("SharedContextLinkCreator", fields: [createdById], references: [id], onDelete: SetNull)

  @@index([contextId])
}

enum SharedContextStatus {
  ACTIVE
  ARCHIVED
}

enum ContextAudience {
  PROSPECT     // Lo que le contaríamos al cliente
  INTERNAL     // Versión interna completa (default)
  FINANCE      // Para conversaciones con CFO/Finanzas
  TECHNICAL    // Para áreas técnicas/integración
  EXECUTIVE    // 1-pager ejecutivo
}

enum ContextLinkType {
  PRESENTATION
  DOCUMENT
  SPREADSHEET
  LOVABLE
  FIGMA
  VIDEO
  WEBSITE
  REPO
  OTHER
}

/// OPT-016: Cache compartido cross-instance/region.
/// `unstable_cache` de Next.js es per-Vercel-function — en cold start
/// se evapora y se vuelve a calcular. Esta tabla actúa como L2 cache
/// que sobrevive a cold starts y es compartida entre todas las
/// invocaciones serverless.
///
/// Patrón de uso: helper `cached(key, ttlMs, fn)` en
/// `src/lib/shared/shared-cache.ts`. La tabla se limpia lazily
/// (cada lectura que detecta expiresAt < now() borra esa fila).
model Cache {
  key       String   @id
  value     Json
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([expiresAt])
}
